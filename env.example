# OpenClaw A2A shared configuration
# Copy to .env and fill in values before running setup-a2a.sh
#
# Usage:
#   cp env.example .env
#   # Edit .env with your values
#   ./scripts/setup-a2a.sh alice
#   ./scripts/setup-a2a.sh bob
#
# Per-user files (.env.alice, .env.bob) are auto-generated by setup-a2a.sh.
# This file holds shared config that all agents use.

# === Model Provider ===
# External vLLM / LiteLLM endpoint (OpenAI-compatible /v1 URL)
MODEL_ENDPOINT=https://litellm-prod.apps.maas.redhatworkshops.io/v1

# API key for the model endpoint
MODEL_API_KEY=sk-change-me

# Model ID and display name (as registered in the endpoint)
# MODEL_NAME=deepseek-r1-distill-qwen-14b
# MODEL_DISPLAY_NAME=DeepSeek R1 Distill Qwen 14B

# === Observability ===
# MLflow tracking URI (auto-detected from cluster if left empty)
# MLFLOW_TRACKING_URI=http://mlflow-service.mlflow.svc.cluster.local:5000
# MLFLOW_EXPERIMENT_ID=0

# === Kagenti / Keycloak ===
# KEYCLOAK_REALM=kagenti
# KEYCLOAK_NAMESPACE=keycloak
