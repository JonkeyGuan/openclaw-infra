apiVersion: v1
kind: ConfigMap
metadata:
  name: openclaw-config
  namespace: openclaw
data:
  openclaw.json: |
    {
      "plugins": {
        "allow": ["diagnostics-otel"],
        "entries": {
          "diagnostics-otel": {"enabled": true}
        }
      },
      "gateway": {
        "mode": "local",
        "bind": "loopback",
        "port": 18789,
        "auth": {"mode": "token", "allowTailscale": false},
        "controlUi": {"enabled": true, "dangerouslyDisableDeviceAuth": true},
        "http": {"endpoints": {"chatCompletions": {"enabled": true}}}
      },
      "diagnostics": {
        "enabled": true,
        "otel": {
          "enabled": true,
          "endpoint": "http://localhost:4318",
        }
      },
      "models": {
        "providers": {
          "local": {
            "baseUrl": "${MODEL_ENDPOINT}",
            "api": "openai-completions",
            "apiKey": "${MODEL_API_KEY}",
            "models": [
              {
                "id": "${MODEL_NAME}",
                "name": "${MODEL_DISPLAY_NAME}",
                "reasoning": true,
                "input": ["text"],
                "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
                "contextWindow": 32768,
                "maxTokens": 8192
              }
            ]
          }
        }
      },
      "tools": {
        "allow": [
          "read", "write", "edit", "exec",
          "web_search",
          "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "session_status",
          "agents_list", "cron"
        ],
        "deny": [
          "message", "web_fetch", "browser", "canvas", "nodes", "process", "tts", "gateway"
        ],
        "exec": {
            "security": "full",
            "safeBins": ["cat", "curl", "jq"],
            "safeBinProfiles": {
              "cat": {},
              "curl": {"deniedFlags": ["-o", "--output", "-O", "--remote-name", "--upload-file", "-T"]}
            },
            "timeoutSec": 30
          },
        "agentToAgent": {
          "enabled": true,
          "allow": ["*"]
        }
      },
      "agents": {
        "defaults": {
          "workspace": "~/.openclaw/workspace",
          "model": {"primary": "${DEFAULT_AGENT_MODEL}"},
          "compaction": {
            "reserveTokensFloor": 8000
          }
        },
        "list": [
          {
            "id": "${OPENCLAW_PREFIX}_${SHADOWMAN_CUSTOM_NAME}",
            "name": "${SHADOWMAN_DISPLAY_NAME}",
            "workspace": "~/.openclaw/workspace-${OPENCLAW_PREFIX}_${SHADOWMAN_CUSTOM_NAME}",
            "model": {"primary": "${DEFAULT_AGENT_MODEL}"},
            "subagents": {"allowAgents": ["*"]}
          }
        ]
      },
      "skills": {
        "load": {
          "extraDirs": ["~/.openclaw/skills"],
          "watch": true,
          "watchDebounceMs": 1000
        }
      },
      "channels": {
        "telegram": {
          "dmPolicy": "allowlist",
          "allowFrom": [${TELEGRAM_ALLOW_FROM}]
        }
      },
      "cron": {"enabled": true}
    }
